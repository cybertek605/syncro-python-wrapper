# Syncro API Configuration
# Replace these values with your own Syncro instance details

# Syncro API Base URL (e.g., https://yourdomain.syncromsp.com/api/v1/)
SYNCRO_API_BASE_URL=https://yoursubdomain.syncromsp.com/api/v1/

# Syncro API Token
SYNCRO_API_TOKEN=your_api_token_here

# Return Pydantic Models instead of dictionaries
SYNCRO_RETURN_MODELS=False

# Retry Configuration
SYNCRO_MAX_RETRIES=3
SYNCRO_RETRY_DELAY=2

# Unified Custom Field Type ID (Optional)
SYNCRO_UNIFIED_CUSTOM_FIELD_TYPE_ID=0

# Labor Category ID (Optional)
SYNCRO_LABOR_CATEGORY_ID=0

# Company Configuration
COMPANY_NAME=Your Company Name
